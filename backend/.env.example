# Servidor
PORT=3001

# Frontend autorizado a llamar al backend. En Render agrega tu dominio real.
FRONTEND_ORIGINS=http://localhost:5173,https://www.orviane.com

# Base de datos. En local puedes usar Postgres propio o el de Docker Compose.
DATABASE_URL=postgresql://usuario:password@localhost:5432/el_atelier_artesanal
DATABASE_SSL=false

# Seguridad. Genera valores largos y aleatorios.
AUTH_JWT_SECRET=define_un_secreto_seguro_para_jwt
OPERATIONS_ACCESS_TOKEN=define_un_token_largo_para_make_y_panel
OPERATIONS_ADMIN_EMAILS=tu_correo_admin@orviane.com
OPERATIONS_ADMIN_SEED_EMAIL=operaciones@orviane.com
OPERATIONS_ADMIN_SEED_PASSWORD=define_una_contrasena_segura
OPERATIONS_ADMIN_SEED_FULL_NAME=Administrador Orviane
OPERATIONS_ADMIN_SEED_WHATSAPP=

# Persistencia auxiliar de usuarios.
USERS_DUAL_WRITE_FILE=true
USERS_FILE_FALLBACK_READS=true

# Google Sign-In. Si no lo usas, déjalo en false.
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_SIGN_IN_ENABLED=false

# Google Cloud / Vertex AI (para generación de imágenes y asistente con Gemini).
# - En desarrollo local: usa GOOGLE_APPLICATION_CREDENTIALS o la variable de la raíz para Docker.
# - En Render: usa GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 (recomendado) o GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_CLOUD_PROJECT_ID=orviane-studio-ia
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_PUBLISHER=google
GOOGLE_CLOUD_MODEL=imagen-4.0-generate-001

# Modelos de IA. Si no los cambias, puedes dejar los valores por defecto.
ASSISTANT_V2_MODEL=gemini-2.5-flash
OPENAI_API_KEY=sk-proj-tu_clave_openai
OPENAI_ASSISTANT_MODEL=gpt-5-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Tabla de referencia para el calculador de metales (no tocar a menos que cambies precios).
ORVIA_VALUATION_METAL_PRICES_COP_JSON={"oro amarillo 18k":399000,"oro blanco 18k":419000,"oro rosado 18k":399000,"oro amarillo 14k":310000,"oro blanco 14k":325000,"oro rosado 14k":310000,"oro 24k":532000,"plata 925":8200,"plata pura":8900,"platino":227000,"paladio":159000,"cobre":50,"aluminio":15}

# Nota: Azure OpenAI fue removido. El asistente Orvia usa:
# - OpenAI (si defines OPENAI_API_KEY)
# - Vertex AI / Gemini (si tienes credenciales de Google Cloud)
# Si ninguna está configurada, usa un modo de reglas local como fallback.
