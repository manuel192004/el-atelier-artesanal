# URL del backend. En local normalmente es localhost:3001.
VITE_API_BASE_URL=http://localhost:3001

# Client ID de Google OAuth para el frontend.
VITE_GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com

# Activa solo si el backend también tiene Google Sign-In configurado.
VITE_GOOGLE_SIGN_IN_ENABLED=false
